# Refúgio do Cuscuzeiro - Cache Headers Otimização
# Configuração de expiração de cache para máxima performance

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 hour"
    
    # Imagens - 1 ano (cache muito agressivo pois são estáticas com versionamento)
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    
    # CSS e JavaScript - 1 dia (revalidar diariamente)
    ExpiresByType text/css "access plus 1 day"
    ExpiresByType application/javascript "access plus 1 day"
    ExpiresByType text/javascript "access plus 1 day"
    
    # Fontes - 1 ano
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    
    # HTML - não cache (ou 1 hora para fallback)
    ExpiresByType text/html "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
    # Imagens WebP e estáticas - expiração 1 ano
    <FilesMatch "\.(webp|jpg|jpeg|png|gif|ico|woff|woff2|ttf|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # CSS e JS - 1 dia
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>
    
    # HTML - sem cache (sempre validar)
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>
    
    # Service Worker - sem cache
    <FilesMatch "service-worker\.js$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>
    
    # Adicionar headers de compressão
    <FilesMatch "\.(css|js|svg)$">
        Header set Vary "Accept-Encoding"
    </FilesMatch>
</IfModule>

# Habilitar gzip compression
<IfModule mod_gzip.c>
    mod_gzip_on Yes
    mod_gzip_dechunk Yes
    mod_gzip_item_include file .(html|txt|xml|php|css|js|svg)$
    mod_gzip_item_include handler ^cgi-script$
    mod_gzip_item_exclude mime ^image/
    mod_gzip_minimum_file_size 300
    mod_gzip_maximum_file_size 512000
    mod_gzip_level 6
</IfModule>

# Alternativa: deflate para compressão se gzip não estiver disponível
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Adicionar tipo MIME para WebP
<IfModule mod_mime.c>
    AddType image/webp .webp
</IfModule>

# ETag para validação de cache eficiente
<IfModule mod_headers.c>
    Header set ETag "%{FILE_SIZE}o-%{FILE_MTIME}X-%{HTTP_HOST}e"
</IfModule>
